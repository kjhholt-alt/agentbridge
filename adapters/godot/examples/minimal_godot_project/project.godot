; Engine configuration file.
;
; AgentBridge minimal example -- proves the addon loads + bridge listens
; under the AGENTBRIDGE=1 env gate. Used by the conformance suite.

config_version=5

[application]

config/name="AgentBridge Minimal"
config/description="Minimal scene that loads addons/agentbridge and proves the bridge boots cleanly."
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6")

[editor_plugins]

enabled=PackedStringArray("res://addons/agentbridge/plugin.cfg")

